<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<StackPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.crm.controller.LoginController" styleClass="auth-page">
    <VBox maxWidth="430" spacing="20" styleClass="auth-card">
        <VBox alignment="CENTER" spacing="8"><ImageView fitWidth="64" fitHeight="64" preserveRatio="true" smooth="true"><image><Image url="@/images/app-icon.png"/></image></ImageView><Label text="VoidReach CRM" styleClass="auth-brand"/><Label text="Sign in to your workspace" styleClass="auth-subtitle"/></VBox>
        <VBox fx:id="loginPane" spacing="12"><Label text="Welcome back" styleClass="auth-title"/><TextField fx:id="loginEmail" promptText="Email"/><PasswordField fx:id="loginPassword" promptText="Password" onAction="#handleLogin"/><CheckBox fx:id="rememberLogin" text="Stay signed in on this device" styleClass="auth-checkbox"/><Label fx:id="loginMessage" styleClass="auth-message" wrapText="true"/><Button text="Sign in" onAction="#handleLogin" maxWidth="1.7976931348623157E308" styleClass="auth-primary"/><Hyperlink text="Forgot your password?" onAction="#showRecovery"/><HBox alignment="CENTER"><Label text="Don't have an account?"/><Hyperlink text="Sign up" onAction="#showRegister"/></HBox></VBox>
        <VBox fx:id="registerPane" visible="false" managed="false" spacing="12"><Label text="Create an account" styleClass="auth-title"/><TextField fx:id="registerName" promptText="Full name"/><TextField fx:id="registerEmail" promptText="Email"/><PasswordField fx:id="registerPassword" promptText="Password (at least 8 characters)"/><PasswordField fx:id="registerPasswordConfirm" promptText="Confirm password" onAction="#handleRegister"/><Label fx:id="registerMessage" styleClass="auth-message" wrapText="true"/><Button text="Create account" onAction="#handleRegister" maxWidth="1.7976931348623157E308" styleClass="auth-primary"/><Hyperlink text="Already have an account? Sign in" onAction="#showLogin"/></VBox>
        <VBox fx:id="recoveryPane" visible="false" managed="false" spacing="12"><Label text="Recover password" styleClass="auth-title"/><Label text="Enter your account email. In production, the code will be sent by email." wrapText="true" styleClass="auth-subtitle"/><TextField fx:id="recoveryEmail" promptText="Email" onAction="#handleRecovery"/><Label fx:id="recoveryMessage" styleClass="auth-message" wrapText="true"/><Button text="Generate code" onAction="#handleRecovery" maxWidth="1.7976931348623157E308" styleClass="auth-primary"/><Hyperlink text="Back to sign in" onAction="#showLogin"/></VBox>
        <VBox fx:id="resetPane" visible="false" managed="false" spacing="12"><Label text="New password" styleClass="auth-title"/><TextField fx:id="resetEmail" promptText="Email" editable="false"/><TextField fx:id="resetCode" promptText="6-digit code"/><PasswordField fx:id="resetPassword" promptText="New password"/><PasswordField fx:id="resetPasswordConfirm" promptText="Confirm new password" onAction="#handleReset"/><Label fx:id="resetMessage" styleClass="auth-message" wrapText="true"/><Button text="Update password" onAction="#handleReset" maxWidth="1.7976931348623157E308" styleClass="auth-primary"/><Hyperlink text="Back to sign in" onAction="#showLogin"/></VBox>
    </VBox>
</StackPane>
